# Скопируйте в .env и подставьте свои значения
# Для локального docker compose можно оставить дефолты

# Django
DJANGO_SECRET_KEY=your-secret-key-min-50-chars
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,your-app.onrender.com

# PostgreSQL (для docker-compose задаются в environment, здесь для локального run)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=edulife_db
POSTGRES_USER=edulife
POSTGRES_PASSWORD=edulife_secret

# MinIO / S3 (на бесплатном хостинге часто подключают внешний S3 или R2)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_USE_SSL=false
MINIO_BUCKET_NAME=edulife

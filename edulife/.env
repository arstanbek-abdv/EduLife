# EduLife — скопируйте как есть для запуска из edulife/: docker compose up -d
# Для продакшена смените DJANGO_SECRET_KEY и поставьте DJANGO_DEBUG=false

# Django
DJANGO_SECRET_KEY=django-insecure-change-in-production-min-50-chars
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# PostgreSQL (имена должны совпадать с db в docker-compose)
POSTGRES_DB=edulife_db
POSTGRES_USER=edulife
POSTGRES_PASSWORD=edulife_secret

# MinIO
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET_NAME=edulife
